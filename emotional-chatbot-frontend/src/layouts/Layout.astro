---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Acompañamiento Emocional' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Chatbot de apoyo emocional inicial con análisis no clínico." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-mint-50 text-slate-800 antialiased">
    <slot />
  </body>
</html>
